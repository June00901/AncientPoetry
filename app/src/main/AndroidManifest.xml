<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ee.example.ancient">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@drawable/img"
        android:label="@string/app_name"
        android:roundIcon="@drawable/img"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true">
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".RegiterActivity"
            android:exported="true">
        </activity>

        <activity
            android:name="ee.example.ancient.AddGuShiActivity"
            android:exported="false">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>

        <activity
            android:name="ee.example.ancient.GuShiDetailActivity"
            android:exported="false"
            android:label="详情" />

        <activity
            android:name="ee.example.ancient.MainChangemima"
            android:exported="false" />

        <activity
            android:name="ee.example.ancient.AdminListActivity"
            android:exported="false" />

        <activity android:name=".ThemeListActivity" />

        <activity
            android:name=".MyCollectionActivity"
            android:exported="false"
            android:label="我的收藏" />

        <activity
            android:name=".activity.NoteListActivity"
            android:label="学习笔记与计划" />

        <activity
            android:name=".activity.NoteEditActivity"
            android:label="编辑笔记" />

        <activity
            android:name=".activity.AddNoteActivity"
            android:label="添加笔记" />

        <activity android:name=".AiQAActivity" />

        <activity
            android:name=".AiOnlineSearchActivity"
            android:label="AI深度联网搜索"
            android:theme="@style/AppTheme"
            android:parentActivityName=".MainActivity"/>

        <!-- AI诗词评析页面 -->
        <activity
            android:name=".PoemScoreActivity"
            android:label="AI诗词评析"
            android:theme="@style/AppTheme"
            android:parentActivityName=".MainActivity"/>

        <!-- AI辅助学习计划页面 -->
        <activity
            android:name=".AiStudyPlanActivity"
            android:label="AI辅助学习计划"
            android:theme="@style/AppTheme"
            android:parentActivityName=".MainActivity"/>

        <!-- 学习计划结果页面 -->
        <activity
            android:name=".StudyPlanResultActivity"
            android:label="学习计划详情"
            android:theme="@style/AppTheme"
            android:parentActivityName=".MainActivity"/>

    </application>

</manifest>