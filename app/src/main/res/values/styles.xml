<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="TabLable">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:padding">5dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/tab_bg_selector</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@drawable/tab_text_selector</item>
        <item name="android:drawableTop">@drawable/home</item>

    </style>

    <style name="button">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">#f37301</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="title">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#f37301</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="text">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#f37301</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="content">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#003cda</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>