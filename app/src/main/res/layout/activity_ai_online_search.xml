<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/backbg0">

    <!-- 顶部装饰条 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/ai_header_gradient"
        android:layout_marginBottom="30dp"/>

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ai_helper"
            android:tint="#4A90E2"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI深度联网搜索"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 搜索区域卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/ai_input_card"
        android:padding="24dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="输入搜索内容"
            android:textSize="18sp"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_search_query"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ai_edit_background"
            android:padding="16dp"
            android:hint="例如：静夜思、李白、床前明月光"
            android:textSize="16sp"
            android:maxLines="3"
            android:inputType="textMultiLine"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="16dp"/>

        <!-- 描述型查找古诗 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 描述型查找古诗"
                android:textSize="14sp"
                android:textColor="#E65100"
                android:textStyle="bold"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="忘记诗名？描述内容或意境，AI帮你找"
                android:textSize="12sp"
                android:textColor="#757575"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_desc_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ai_edit_background"
                android:padding="14dp"
                android:hint="例如：有一间大房子庇护很多人"
                android:textSize="15sp"
                android:maxLines="3"
                android:inputType="textMultiLine"
                android:fontFamily="@font/kaiti"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_search"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开始深度搜索"
            android:textSize="18sp"
            android:background="@drawable/ai_button_background"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 结果显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/ai_answer_card"
        android:padding="24dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/t1"
                android:tint="#4A90E2"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="搜索结果"
                android:textSize="18sp"
                android:textColor="#357ABD"
                android:fontFamily="@font/kaiti"/>
        </LinearLayout>

        <ScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp"
                android:fontFamily="@font/kaiti"
                android:padding="4dp"/>
        </ScrollView>
    </LinearLayout>
</LinearLayout>