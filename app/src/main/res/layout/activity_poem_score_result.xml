<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="评分结果"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- 总分卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="综合得分"
                android:textSize="18sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/text_total_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"/>

            <TextView
                android:id="@+id/text_score_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="优秀"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"
                android:layout_marginTop="8dp"/>

            <ProgressBar
                android:id="@+id/progress_score"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="85"
                android:max="100"
                android:layout_marginTop="16dp"/>
        </LinearLayout>

        <!-- 分项得分 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分项评分"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/result_background"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- 平仄韵律 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="平仄韵律"
                    android:textSize="16sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/score_rhythm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28/30"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
            </LinearLayout>

            <!-- 对仗工整 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="对仗工整"
                    android:textSize="16sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/score_antithesis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25/30"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
            </LinearLayout>

            <!-- 意境表达 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="意境表达"
                    android:textSize="16sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/score_artistic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22/25"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFC107"/>
            </LinearLayout>

            <!-- 用词精炼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="用词精炼"
                    android:textSize="16sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/score_wording"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10/15"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>
        </LinearLayout>

        <!-- AI赏析 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI赏析"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/text_appreciation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/result_background"
            android:padding="16dp"
            android:textSize="15sp"
            android:textColor="#555555"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="20dp"/>

        <!-- 指导意见 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="指导意见"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/text_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/result_background"
            android:padding="16dp"
            android:textSize="15sp"
            android:textColor="#555555"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="24dp"/>

        <!-- 返回按钮 -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="返回重新评分"
            android:textSize="16sp"
            android:padding="14dp"
            android:background="@drawable/button_background"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</ScrollView>