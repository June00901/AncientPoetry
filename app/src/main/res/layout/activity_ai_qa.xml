<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/aii_helper">

    <!-- 顶部装饰条 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/ai_header_gradient"
        android:layout_marginBottom="30dp"/>

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ai_helper"
            android:tint="#4A90E2"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI诗词问答"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 输入区域卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/ai_input_card"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请输入你的问题"
            android:textSize="18sp"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/et_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ai_edit_background"
            android:padding="16dp"
            android:hint="例如：静夜思表达了什么情感？"
            android:textSize="16sp"
            android:maxLines="4"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:fontFamily="@font/kaiti"/>

        <Button
            android:id="@+id/btn_ask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="提问"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:background="@drawable/ai_button_background"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 回答区域卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/ai_answer_card"
        android:padding="24dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/t1"
                android:tint="#4A90E2"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI回答"
                android:textSize="18sp"
                android:textColor="#357ABD"
                android:fontFamily="@font/kaiti"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tv_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp"
                android:fontFamily="@font/kaiti"
                android:padding="4dp"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>