<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:background="@drawable/backbg0"
    android:padding="20dp"
    tools:context=".MainActivity">

    <!-- 顶部装饰条 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/ai_header_gradient"
        android:layout_marginBottom="30dp"/>

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/find"
            android:tint="#4A90E2"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="古诗词搜索"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 搜索区域卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/ai_input_card"
        android:padding="24dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="搜索古诗词"
            android:textSize="18sp"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <SearchView
                android:id="@+id/sv"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/ai_edit_background"
                android:iconifiedByDefault="false"
                android:queryBackground="@null"
                android:queryHint="请输入搜索古诗词名、作者或诗句"
                android:fontFamily="@font/kaiti"/>

            <Button
                android:id="@+id/btn_search"
                android:layout_width="100dp"
                android:layout_height="52dp"
                android:text="搜索"
                android:textSize="16sp"
                android:background="@drawable/ai_button_secondary"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/kaiti"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="描述型查找古诗"
            android:textSize="16sp"
            android:textColor="#357ABD"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_desc_search"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/ai_edit_background"
            android:hint="例如：描述有一间大房子庇护很多人的古诗"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColorHint="#9E9E9E"
            android:fontFamily="@font/kaiti"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_ai_search"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="AI深度联网搜索"
            android:textSize="16sp"
            android:background="@drawable/ai_button_secondary"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/kaiti"/>
    </LinearLayout>

    <!-- 结果显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/ai_answer_card"
        android:padding="24dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/t1"
                android:tint="#4A90E2"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="搜索结果"
                android:textSize="18sp"
                android:textColor="#357ABD"
                android:fontFamily="@font/kaiti"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

</LinearLayout>