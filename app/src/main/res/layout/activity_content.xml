<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部图片区域 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/conImage1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_card_white_rounded"/>

            <!-- 半透明渐变覆盖层 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_overlay"/>

            <!-- 返回按钮 -->
            <Button
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:background="@drawable/circle_white_bg"
                android:text="←"
                android:textSize="20sp"
                android:textColor="#333333"/>

        </RelativeLayout>

        <!-- 内容区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white_rounded"
            android:layout_marginTop="-24dp"
            android:padding="24dp"
            android:elevation="4dp">

            <!-- 标题 -->
            <TextView
                android:id="@+id/conText1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:gravity="center"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="16dp"/>

            <!-- 诗词内容 -->
            <TextView
                android:id="@+id/conText2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="#34495E"
                android:lineSpacingExtra="16dp"
                android:gravity="center"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="32dp"
                android:paddingHorizontal="16dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="24dp"/>

            <!-- 译文 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="译文"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/translation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#7F8C8D"
                android:lineSpacingExtra="12dp"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="32dp"
                android:paddingHorizontal="8dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="24dp"/>

            <!-- 诗人信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="诗人信息"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/poetInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#7F8C8D"
                android:lineSpacingExtra="12dp"
                android:fontFamily="@font/kaiti"
                android:layout_marginBottom="32dp"
                android:paddingHorizontal="8dp"/>

            <!-- 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnCollect"
                    android:layout_width="160dp"
                    android:layout_height="48dp"
                    android:text="收藏"
                    android:layout_gravity="center"
                    android:background="@drawable/button_primary_rounded"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/kaiti"
                    android:textSize="16sp"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp"/>

                <Button
                    android:id="@+id/btn_share"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="分享"
                    android:background="@drawable/button_secondary_rounded"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/kaiti"
                    android:elevation="2dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

    </LinearLayout>
</ScrollView> 